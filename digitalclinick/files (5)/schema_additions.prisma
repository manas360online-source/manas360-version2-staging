// Extend existing MdcClinic model — add these fields:
// clinic_code  String?  @unique @db.VarChar(10)
// max_therapists Int    @default(5)

model MdcTherapist {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId        String    @map("clinic_id") @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  slotNumber      Int       @map("slot_number")
  loginSuffix     String    @unique @map("login_suffix") @db.VarChar(15)
  displayName     String    @map("display_name") @db.VarChar(200)
  role            String    @default("therapist") @db.VarChar(20) // admin | therapist
  specialization  String?   @db.VarChar(100)
  isActive        Boolean   @default(true) @map("is_active")
  invitedAt       DateTime? @map("invited_at")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  clinic          MdcClinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id])

  @@unique([clinicId, slotNumber])
  @@index([clinicId])
  @@index([userId])
  @@map("mdc_therapists")
}

model MdcImportRow {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId      String   @map("import_id") @db.Uuid
  rowNumber     Int      @map("row_number")
  rawData       Json     @map("raw_data")
  patientId     String?  @map("patient_id") @db.Uuid
  status        String   @default("pending") @db.VarChar(20) // pending | imported | skipped | error
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  import        MdcPatientImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  patient       MdcPatient?      @relation(fields: [patientId], references: [id])

  @@index([importId])
  @@index([importId, status])
  @@map("mdc_import_rows")
}

model MdcSessionRoom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  clinicId        String    @map("clinic_id") @db.Uuid
  roomId          String    @unique @map("room_id") @db.VarChar(100)
  mode            String    @default("audio") @db.VarChar(10) // audio | video
  jitsiUrl        String    @map("jitsi_url")
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  createdAt       DateTime  @default(now()) @map("created_at")

  session         MdcSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  clinic          MdcClinic  @relation(fields: [clinicId], references: [id])

  @@index([sessionId])
  @@index([clinicId])
  @@map("mdc_session_rooms")
}

