# PhonePe Integration - Environment Variables for Testing
# Date: April 2, 2026
# Reference: /phonepay.md + phonepe.service.ts

# ============================================================================
# 1. CORE AUTHENTICATION (REQUIRED FOR TESTING)
# ============================================================================

# Test Mode: Set to 'preprod' for PhonePe Sandbox (UAT)
PHONEPE_ENV=preprod

# PhonePe Merchant ID (from PhonePe Business Dashboard - Test Mode ON)
PHONEPE_MERCHANT_ID=PGCHECKOUT

# PhonePe OAuth Credentials (Get from PhonePe Business Dashboard)
# These are your Client ID and Client Secret
PHONEPE_CLIENT_ID=<your-test-client-id>
PHONEPE_CLIENT_SECRET=<your-test-client-secret>

# Client Version (from PhonePe Business Dashboard)
PHONEPE_CLIENT_VERSION=1

# ============================================================================
# 2. WEBHOOK CREDENTIALS (REQUIRED FOR WEBHOOK TESTING)
# ============================================================================

# Webhook username and password (configured in PhonePe Dashboard under Webhook Settings)
PHONEPE_WEBHOOK_USERNAME=<your-webhook-username>
PHONEPE_WEBHOOK_PASSWORD=<your-webhook-password>

# Webhook IP Allowlist (additional IPs beyond PhonePe's official list)
# Format: comma-separated, e.g. "1.2.3.4,5.6.7.8"
PHONEPE_WEBHOOK_ALLOWED_IPS=

# ============================================================================
# 3. OPTIONAL: LEGACY SALT KEY (Checksum Mode - If Not Using OAuth)
# ============================================================================

# Salt Key (only needed if using checksum/salt mode instead of OAuth)
# Leave empty to use OAuth V2 (recommended)
PHONEPE_SALT_KEY=

# Salt Index (only relevant with PHONEPE_SALT_KEY)
PHONEPE_SALT_INDEX=1

# ============================================================================
# 4. OPTIONAL: CUSTOM ENDPOINTS (Usually not needed for testing)
# ============================================================================

# Custom PhonePe Base URL (leave empty for auto-detection based on PHONEPE_ENV)
# PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/hermes

# Custom OAuth URL (leave empty for auto-detection)
# PHONEPE_OAUTH_URL=https://api-preprod.phonepe.com/apis/identity-manager/v1/oauth/token

# Custom Status Endpoint Template (use {merchantTransactionId} as placeholder)
# PHONEPE_STATUS_ENDPOINT_TEMPLATE=/checkout/v2/order/{merchantTransactionId}/status

# ============================================================================
# 5. TESTING MODE FLAGS
# ============================================================================

# Allow PhonePe webhook IP bypass in non-production (for local testing)
ALLOW_PHONEPE_WEBHOOK_IP_BYPASS=true

# Allow probe-only webhook requests (for testing webhook endpoint connectivity)
ALLOW_DEV_PHONEPE_WEBHOOK_PROBE_BYPASS=true

# Allow payment creation bypass in development (for testing without real payments)
ALLOW_DEV_PAYMENT_BYPASS=false

# ============================================================================
# 6. APPLICATION ENVIRONMENT
# ============================================================================

# Node environment (development/test for testing, production for live)
NODE_ENV=development

# API Base URL (for webhook callbacks)
API_URL=http://localhost:3000

# API Prefix
API_PREFIX=/api

# Frontend URL (for payment redirect after completion)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# 7. PAYMENT CONFIGURATION
# ============================================================================

# Platform/Provider split percentages
PAYMENT_PLATFORM_SHARE_PERCENT=40
PAYMENT_PROVIDER_SHARE_PERCENT=60

# Default order expiry in seconds (recommended: 1800 = 30 minutes)
# Will be clamped to [300, 3600] range
PHONEPE_EXPIRY_SECONDS=1800

# ============================================================================
# 8. REDIS/CACHE (For Idempotency)
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# 9. DATABASE
# ============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/manas360_test

# ============================================================================
# IMPORTANT TESTING NOTES
# ============================================================================

# How to get Test Credentials:
# 1. Go to PhonePe Business Dashboard: https://dashboard.phonepe.com
# 2. Set "Test Mode" toggle to ON (upper right corner)
# 3. Copy your Client ID and Client Secret
# 4. Use PHONEPE_ENV=preprod or PHONEPE_MODE=pgsandbox

# Testing Workflow:
# 1. Set up all REQUIRED variables (marked above)
# 2. Set ALLOW_PHONEPE_WEBHOOK_IP_BYPASS=true for local testing
# 3. Configure webhook URL in PhonePe Dashboard: http://your-ngrok-url/api/v1/payments/phonepe/webhook
# 4. Test payment flow:
#    - Initiate payment → User redirected to PhonePe checkout
#    - Complete payment → Webhook callback to your endpoint
#    - Verify status → Check order status endpoint
# 5. Monitor logs for guideline compliance messages

# Webhook Testing (Local Development):
# - Use ngrok to expose local endpoint: ngrok http 3000
# - Register webhook URL in PhonePe Dashboard: https://your-ngrok-url/api/v1/payments/phonepe/webhook
# - Configure PHONEPE_WEBHOOK_USERNAME and PHONEPE_WEBHOOK_PASSWORD to match dashboard settings

# Expected Log Messages During Testing:
# ✓ [PhonePe] Token refresh scheduled
# ✓ [PhonePe] Initiating payment
# ✓ [Payment.Reconcile] Starting status reconciliation (strict PhonePe guideline schedule)
# ✓ [PhonePeWebhook] Order completed

# Troubleshooting:
# - "OAuth token unavailable" → Check PHONEPE_CLIENT_ID/PHONEPE_CLIENT_SECRET
# - "Webhook signature verification FAILED" → Check PHONEPE_WEBHOOK_USERNAME/PASSWORD match dashboard
# - "Unauthorized source IP" → Enable ALLOW_PHONEPE_WEBHOOK_IP_BYPASS=true for local testing
# - "Amount must be at least 100 paise" → Test amounts must be >= ₹1.00
