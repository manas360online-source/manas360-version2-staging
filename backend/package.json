{
	"name": "manas360-backend",
	"version": "1.0.0",
	"private": true,
	"main": "dist/server.js",
	"prisma": {
		"seed": "node ./prisma/seed.js"
	},
	"scripts": {
		"predev": "npm run prisma:generate",
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"prebuild": "npm run prisma:generate",
		"build": "tsc -p tsconfig.json",
		"prestart": "",
		"start": "node dist/server.js",
		"typecheck": "tsc --noEmit",
		"prisma:generate": "prisma generate",
		"prisma:validate": "prisma validate",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"prisma:migrate:dev": "prisma migrate dev",
		"migration:generate": "./scripts/generate_incremental_migration.sh",
		"migration:apply": "./scripts/apply_migration.sh",
		"test": "jest --runInBand",
		"test:chat": "jest --runInBand chat.integration.test.ts chat-route.integration.test.ts",
		"backfill:versions": "ts-node ./scripts/backfill_versions.ts",
		"health:predeploy": "bash ./scripts/predeploy-health-check.sh",
		"smoke:patient:saas": "bash ./scripts/run-patient-saas-smoke.sh",
		"guard:single-admin": "node ./scripts/check-single-platform-admin.js",
		"test:watch": "jest --watch"
		,"send:zoho:event": "node ./scripts/send-zoho-event.js"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.750.0",
		"@aws-sdk/s3-request-presigner": "^3.750.0",
		"@prisma/adapter-pg": "^7.5.0",
		"@sentry/node": "^10.44.0",
		"@sentry/profiling-node": "^10.44.0",
		"@socket.io/redis-adapter": "^8.3.0",
		"@types/cors": "^2.8.19",
		"axios": "^1.6.0",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.70.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"cuid": "^3.0.0",
		"dotenv": "^17.3.1",
		"express": "^4.21.2",
		"express-rate-limit": "^7.5.0",
		"express-validator": "^7.2.1",
		"fast-csv": "^5.0.5",
		"google-auth-library": "^9.15.1",
		"helmet": "^8.0.0",
		"jsonwebtoken": "^9.0.3",
		"multer": "^1.4.5-lts.1",
		"node-cron": "^4.2.1",
		"openid-client": "^6.8.2",
		"otplib": "^12.0.1",
		"pdfkit": "^0.17.2",
		"pg": "^8.20.0",
		"redis": "^5.11.0",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.0",
		"uuid": "^9.0.0",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0",
		"xlsx": "^0.18.5"
	},
	"optionalDependencies": {
		"prom-client": "^14.2.0"
	},
	"devDependencies": {
		"@prisma/client": "^4.16.2",
		"@types/bcrypt": "^5.0.2",
		"@types/cookie-parser": "^1.4.8",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.13.10",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.18.0",
		"@types/supertest": "^6.0.3",
		"jest": "^29.7.0",
		"prisma": "^4.16.2",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.8.2"
	},
	"overrides": {
		"tar": "7.5.8"
	}
}
