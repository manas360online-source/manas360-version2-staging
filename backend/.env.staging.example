NODE_ENV=staging
PORT=5000
API_PREFIX=/api
CORS_ORIGIN=https://staging.myapp.com
FRONTEND_URL=https://staging.myapp.com

DATABASE_URL=postgresql://manas360:REPLACE_ME@localhost:5432/manas360_staging
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=true
SESSION_NOTES_ENCRYPTION_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku
CLAUDE_SONNET_MODEL=claude-3-5-sonnet-20241022

# Optional outbound email connector for staging
EMAIL_PROVIDER=
EMAIL_WEBHOOK_URL=
EMAIL_FROM_NAME=MANAS360
EMAIL_FROM_ADDRESS=noreply@manas360.com
EMAIL_REPLY_TO=support@manas360.com

# Optional platform admin invite email customization
ADMIN_INVITE_EMAIL_SUBJECT=Your MANAS360 admin invitation
ADMIN_INVITE_LOGIN_URL=https://staging.myapp.com/admin-portal/login

# Zoho Flow webhook (incoming) — set this to your Zoho Flow incoming webhook URL.
# Example (DO NOT COMMIT your real URL/key):
# ZOHO_FLOW_WEBHOOK_URL=https://flow.zoho.in/60067414515/flow/webhook/incoming?zapikey=YOUR_REAL_KEY&isdebug=false
# Optional shared secret for inbound verification from Zoho Flow (use for HMAC/header checks):
# ZOHO_FLOW_WEBHOOK_SECRET=change-to-a-random-secret
ZOHO_FLOW_WEBHOOK_URL=
ZOHO_FLOW_WEBHOOK_SECRET=
