// Smart Match appointment request: patient submits availability, system matches up to 3 providers
model AppointmentRequest {
  id                    String                    @id @default(uuid())
  patientId             String
  // Availability preferences (JSON): { daysOfWeek: [0-6], timeSlots: [{ startMinute, endMinute }] }
  availabilityPrefs     Json
  // Array of provider objects: [{ providerId, status, rejectedAt?, acceptedAt? }]
  providers             Json                      @default("[]")
  acceptedProviderId    String?                   @map("accepted_provider_id")
  scheduledAt           DateTime?                 @map("scheduled_at")
  durationMinutes       Int                       @default(50) @map("duration_minutes")
  preferredSpecialization String?                @map("preferred_specialization")
  // Payment deadline = scheduledAt - 6 hours. Must pay by this to lock the session.
  paymentDeadlineAt     DateTime?                 @map("payment_deadline_at")
  // Razorpay payment fields (only created once provider accepts)
  razorpayOrderId       String?                   @map("razorpay_order_id") @unique
  razorpayPaymentId     String?                   @map("razorpay_payment_id")
  amountMinor           BigInt?
  currency              String                    @default("INR")
  status                AppointmentRequestStatus  @default(PENDING)
  // Expiry allows stale requests to be auto-cleaned (e.g. 24 hours if no provider accepts)
  expiresAt             DateTime?                 @map("expires_at")
  cancelledAt           DateTime?                 @map("cancelled_at")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  patient  User @relation("AppointmentRequestPatient", fields: [patientId], references: [id], onDelete: Cascade)
  acceptedProvider User? @relation("AppointmentRequestAcceptedProvider", fields: [acceptedProviderId], references: [id], onDelete: SetNull)

  @@index([patientId, status, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@index([acceptedProviderId])
  @@map("appointment_requests")
}

