  invoiceUrl String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("patient_invoices")
}

model PatientExercise {
  id         String   @id @default(uuid())
  patientId  String
  title      String
  assignedBy String
  duration   Int
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // NOTE: assignedBy is currently mock therapist reference.
  // Replace with real therapist relation once therapist module is built.
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@map("patient_exercises")
}

model PatientProgress {
  id                 String   @id @default(uuid())
  patientId          String   @unique
  sessionsCompleted  Int      @default(0)
  totalSessions      Int      @default(0)
  exercisesCompleted Int      @default(0)
  totalExercises     Int      @default(0)
  phqStart           Int?
  phqCurrent         Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_progress")
}

model RevenueLedger {
  id                      String                @id @default(uuid())
  type                    RevenueType
  grossAmountMinor        BigInt
  platformCommissionMinor BigInt
  providerShareMinor      BigInt
  paymentType             FinancialPaymentType?
  taxAmountMinor          BigInt                @default(0)
  currency                String                @default("INR")
  referenceId             String
  paymentId               String?
  sessionId               String?
  subscriptionId          String?
  createdAt               DateTime              @default(now())

  payment            FinancialPayment?        @relation("PaymentRevenueLedger", fields: [paymentId], references: [id], onDelete: Restrict)
  session            FinancialSession?        @relation("SessionRevenueLedger", fields: [sessionId], references: [id], onDelete: Restrict)
  subscription       MarketplaceSubscription? @relation("SubscriptionRevenueLedger", fields: [subscriptionId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]      @relation("RevenueWalletTransactions")

  @@index([type, createdAt(sort: Desc)])
  @@index([referenceId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([subscriptionId])
  @@map("revenue_ledger")
}

model WebhookLog {
  id               String               @id @default(uuid())
  provider         WebhookProvider      @default(RAZORPAY)
  eventId          String
  eventType        String
  payloadHash      String
  signature        String
  isSignatureValid Boolean
  processStatus    WebhookProcessStatus @default(RECEIVED)
  firstSeenAt      DateTime             @default(now())
  processedAt      DateTime?
  errorMessage     String?
  sessionId        String?
  subscriptionId   String?
  rawPayload       Json

  @@unique([provider, eventId])
  @@index([eventType, processStatus])
  @@index([firstSeenAt])
  @@map("webhook_logs")
}

model FinancialAuditLog {
  id         String                  @id @default(uuid())
  actorType  FinancialAuditActorType
  actorId    String?
  action     String
  entityType String
  entityId   String
  reason     String?
  beforeJson Json?
  afterJson  Json?
  traceId    String?
  createdAt  DateTime                @default(now())

  actor User? @relation("UserFinancialAudits", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorType, createdAt(sort: Desc)])
  @@index([traceId])
  @@map("financial_audit_logs")
}

model Certification {
  id                 String             @id @default(uuid())
  slug               String             @unique
  code               String             @unique
  title              String
  shortTitle         String?
  subtitle           String
  level              CertificationLevel
  levelBadge         String
  journeyDescription String
  durationLabel      String
  investmentLabel    String
  monthlyIncomeLabel String?
  modulesCount       Int?
  deliveryMode       String?
  sessionRateLabel   String?
  outcomeLabel       String?
  prerequisitesLabel String
  primaryCtaLabel    String
  secondaryCtaLabel  String             @default("Learn More")
  isInvitationOnly   Boolean            @default(false)
  enrollmentOpen     Boolean            @default(true)
  sortOrder          Int                @default(100)
  isActive           Boolean            @default(true)
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([level, sortOrder])
  @@index([isActive, sortOrder])
  @@map("certifications")
}

// ============ THERAPY PLANS (Guided Recovery) ============

enum PlanActivityFrequency {
  DAILY_RITUAL
  WEEKLY_MILESTONE
  ONE_TIME
}

enum PlanActivityType {
  MOOD_CHECKIN
  EXERCISE
  AUDIO_THERAPY
  CLINICAL_ASSESSMENT
  READING_MATERIAL
  SESSION_BOOKING
}

model TherapyPlan {
  id          String  @id @default(uuid())
  patientId   String
  therapistId String?

  title        String
  providerNote String?

  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient    PatientProfile        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist  User?                 @relation("TherapistPlans", fields: [therapistId], references: [id], onDelete: SetNull)
  activities TherapyPlanActivity[]

  @@index([patientId, status])
  @@map("therapy_plans")
}

model TherapyPlanActivity {
  id     String @id @default(uuid())
  planId String

  title        String
  frequency    PlanActivityFrequency @default(ONE_TIME)
  activityType PlanActivityType

  referenceId String?

  estimatedMinutes Int? @default(5)
  orderIndex       Int  @default(0)
  weekNumber       Int  @default(1)
  isPublished      Boolean @default(false)
  category         String?

  status      String    @default("PENDING")
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan TherapyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("therapy_plan_activities")
}

model Prescription {
  id               String   @id @default(uuid())
  patientId        String   @map("patient_id")
  providerId       String   @map("provider_id")
  drugName         String   @map("drug_name")
  dosage           String
  instructions     String
  prescribedDate   DateTime @default(now()) @map("prescribed_date")
  refillsRemaining Int      @default(0) @map("refills_remaining")
  status           String   @default("ACTIVE")
  adherenceRate    Int      @default(0) @map("adherence_rate")
  warnings         String[] @default([])
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  patient  User @relation("PrescriptionPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider User @relation("PrescriptionProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([providerId, status])
  @@map("prescriptions")
}

model LabOrder {
  id                String   @id @default(uuid())
  patientId         String   @map("patient_id")
  providerId        String   @map("provider_id")
  testName          String   @map("test_name")
  dateOrdered       DateTime @default(now()) @map("date_ordered")
  status            String   @default("PENDING")
  orderingPhysician String   @map("ordering_physician")
  interpretation    String
  biomarkers        Json
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  patient  User @relation("LabOrderPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider User @relation("LabOrderProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([providerId, status])
  @@map("lab_orders")
}

model Goal {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  providerId  String   @map("provider_id")
  title       String
  category    String?
  status      String   @default("IN_PROGRESS")
  startDate   DateTime @default(now()) @map("start_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient  User @relation("GoalPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider User @relation("GoalProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([providerId, status])
  @@map("goals")
}

// ─── Direct Provider ↔ Patient Messaging ────────────────────────────────────

model DirectConversation {
  id              String    @id @default(uuid())
  patientId       String
  providerId      String
  isSupport       Boolean   @default(false)
  lastMessageAt   DateTime?
  lastMessageText String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient  User            @relation("DirectConversationPatient",  fields: [patientId],  references: [id], onDelete: Cascade)
  provider User            @relation("DirectConversationProvider", fields: [providerId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([patientId, providerId])
  @@index([patientId,  lastMessageAt(sort: Desc)])
  @@index([providerId, lastMessageAt(sort: Desc)])
  @@map("direct_conversations")
}

model DirectMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  senderRole     String    // patient | provider | system
  content        String
  messageType    String    @default("TEXT") // TEXT | SYSTEM | ASSESSMENT | SESSION_SUMMARY
  metadata       Json?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("direct_messages")
}

model DailyCheckIn {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  date           DateTime @map("date")
  type           String   // "MORNING" | "EVENING"
  mood           Int      // 1-5 scale
  energy         Int?     // 1-5 scale (morning only)
  sleep          Int?     // 1-5 scale (morning only)
  context        String[] @default([]) // context tags (morning only)
  intention      String?  // daily intention (morning only)
  reflectionGood String?  // what went well (evening only)
  reflectionBad  String?  // what was challenging (evening only)
  stressLevel    Int?     // 1-5 scale (evening only)
  gratitude      String?  // gratitude note (evening only)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  patient User @relation("UserDailyCheckIns", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, date, type], map: "daily_checkins_patient_date_type_uq")
  @@index([patientId, date(sort: Desc)], map: "daily_checkins_patient_date_idx")
  @@map("daily_checkins")
}
