generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  PATIENT
  THERAPIST
  PSYCHIATRIST
  COACH
  ADMIN
}

enum SessionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DEPRECATED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TEXT
  SLIDER
  CHECKBOX
}

enum PatientSessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  PAUSED
}

enum BranchingConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  IN_ARRAY
}

enum UserProvider {
  LOCAL
  GOOGLE
  PHONE
}

enum CertificationLevel {
  ENTRY
  PROFESSIONAL
  MASTERY
}

// ============ USERS ============

model User {
  id                            String       @id @default(uuid())
  name                          String?
  email                         String?      @unique
  phone                         String?      @unique
  firstName                     String       @default("")
  lastName                      String       @default("")
  role                          UserRole
  provider                      UserProvider @default(LOCAL)
  passwordHash                  String?
  googleId                      String?      @unique
  profileImageKey               String?
  profileImageUrl               String?
  showNameToProviders           Boolean      @default(true)
  emailVerified                 Boolean      @default(false)
  phoneVerified                 Boolean      @default(false)
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  phoneVerificationOtpHash      String?
  phoneVerificationOtpExpiresAt DateTime?
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  mfaEnabled                    Boolean      @default(false)
  mfaSecret                     String?
  failedLoginAttempts           Int          @default(0)
  lockUntil                     DateTime?
  lastLoginAt                   DateTime?
  passwordChangedAt             DateTime?
  isDeleted                     Boolean      @default(false)
  deletedAt                     DateTime?
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  // Relations
  therapistSessions         CBTSessionTemplate[]      @relation("TherapistSessions")
  patientSessions           PatientSession[]
  sessionResponses          PatientSessionResponse[]
  patientProfile            PatientProfile?
  therapyBookings           TherapySession[]
  financialPatientSessions  FinancialSession[]        @relation("FinancialPatient")
  financialProviderSessions FinancialSession[]        @relation("FinancialProvider")
  patientLeads              Lead[]                    @relation("LeadPatient")
  providerLeads             Lead[]                    @relation("LeadProvider")
  providerWallet            ProviderWallet?           @relation("ProviderWalletOwner")
  subscriptions             MarketplaceSubscription[] @relation("UserSubscriptions")
  financialAuditEvents      FinancialAuditLog[]       @relation("UserFinancialAudits")
  authSessions              AuthSession[]
  authAuditLogs             AuthAuditLog[]
  aiConversations           AIConversation[]
  notifications             Notification[]
  bookingIntentsAsPatient   SessionBookingIntent[] @relation("BookingIntentPatient")
  bookingIntentsAsProvider  SessionBookingIntent[] @relation("BookingIntentProvider")
  patientSubscription       PatientSubscription?
  patientPaymentMethod      PatientPaymentMethod?
  patientInvoices           PatientInvoice[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isDeleted])
  @@map("users")
}

enum BookingIntentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

model AuthSession {
  id               String   @id @default(uuid())
  userId           String
  jti              String   @unique
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  device           String?
  revokedAt        DateTime?
  expiresAt        DateTime
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  status    String
  email     String?
  phone     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

// ============ CBT SESSION TEMPLATES ============

model CBTSessionTemplate {
  id                       String        @id @default(uuid())
  title                    String
  description              String?
  isOfficial               Boolean       @default(false)
  originTemplateId         String?
  visibility               String        @default("ORG")
  latestPublishedVersionId String?
  version                  Int           @default(1)
  status                   SessionStatus @default(DRAFT)
  category                 String? // e.g., "Anxiety", "Depression", "Sleep"
  targetAudience           String? // e.g., "Adults", "Teenagers"
  estimatedDuration        Int? // in minutes

  // Metadata
  therapistId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  therapist       User                     @relation("TherapistSessions", fields: [therapistId], references: [id], onDelete: Cascade)
  questions       CBTQuestion[]
  patientSessions PatientSession[]
  versions        CBTSessionVersion[]
  tags            TemplateTagOnTemplate[]
  libraries       SessionTemplateLibrary[]

  @@unique([id, version])
  @@index([therapistId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("cbt_session_templates")
}

model TemplateTag {
  id        String                  @id @default(cuid())
  name      String                  @unique
  createdAt DateTime                @default(now())
  templates TemplateTagOnTemplate[]

  @@map("template_tags")
}

model TemplateTagOnTemplate {
  templateId String
  tagId      String
  template   CBTSessionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag        TemplateTag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@index([tagId])
  @@map("template_tags_on_templates")
}

// ============ SESSION VERSIONING ============

model CBTSessionVersion {
  id           String    @id @default(uuid())
  sessionId    String
  version      Int
  snapshotData Json // Full snapshot of template at this version
  changeNotes  String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  publishedAt  DateTime?
  isDraft      Boolean   @default(true)
  checksum     String?

  // Relations
  session CBTSessionTemplate @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, version])
  @@index([sessionId])
  @@index([createdAt])
  @@map("cbt_session_versions")
}

// ============ QUESTIONS ============

model CBTQuestion {
  id          String       @id @default(uuid())
  sessionId   String
  type        QuestionType
  prompt      String
  description String?
  orderIndex  Int // Order within session
  isRequired  Boolean      @default(true)
  helpText    String?

  // Type-specific configurations stored as JSON
  // For MULTIPLE_CHOICE: { options: [{ id, label, value }] }
  // For SLIDER: { min, max, step, labels: { min?, mid?, max? } }
  // For CHECKBOX: { options: [{ id, label, value }] }
  // For TEXT: { minLength?, maxLength?, placeholder?, validationRegex? }
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session              CBTSessionTemplate       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  branchingRules       QuestionBranchingRule[]  @relation("BranchingFromQuestion")
  parentBranchingRules QuestionBranchingRule[]  @relation("BranchingToQuestion")
  responses            PatientResponse[]
  sessionResponses     PatientSessionResponse[]

  @@unique([sessionId, orderIndex])
  @@index([sessionId])
  @@index([orderIndex])
  @@map("cbt_questions")
}

// ============ BRANCHING LOGIC ============

model QuestionBranchingRule {
  id             String                     @id @default(uuid())
  fromQuestionId String
  toQuestionId   String
  condition      Json // { operator: "EQUALS", value: "yes" }
  operator       BranchingConditionOperator
  conditionValue String // The value to match against

  // Optional: Multiple conditions (AND logic)
  // { conditions: [{ operator, value }, ...] }
  complexCondition Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  fromQuestion CBTQuestion @relation("BranchingFromQuestion", fields: [fromQuestionId], references: [id], onDelete: Cascade)
  toQuestion   CBTQuestion @relation("BranchingToQuestion", fields: [toQuestionId], references: [id], onDelete: Cascade)

  @@index([fromQuestionId])
  @@index([toQuestionId])
  @@index([fromQuestionId, toQuestionId])
  @@map("question_branching_rules")
}

// ============ PATIENT SESSIONS (Session Instances) ============

model PatientSession {
  id                String               @id @default(uuid())
  patientId         String
  templateId        String
  templateVersion   Int // Lock to specific template version (deprecated)
  templateVersionId String? // reference to CBTSessionVersion.id
  templateSnapshot  Json? // snapshot of the template at session start (immutable)
  status            PatientSessionStatus @default(NOT_STARTED)

  // Progress tracking
  currentQuestionIndex Int       @default(0)
  completedAt          DateTime?
  abandonedAt          DateTime?
  startedAt            DateTime?

  // Session metadata
  sessionNotes String? // Therapist notes about this session
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  patient   User                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  template  CBTSessionTemplate       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  responses PatientSessionResponse[]
  exports   SessionExport[]

  @@index([patientId])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@index([patientId, status])
  @@map("patient_sessions")
}

// ============ PATIENT PROFILES & HEALTH RECORDS ============

model PatientProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  age              Int
  gender           String
  medicalHistory   String?
  emergencyContact Json
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments     PatientAssessment[]
  moodEntries     PatientMoodEntry[]
  therapySessions TherapySession[]
  exercises       PatientExercise[]
  progress        PatientProgress?

  @@index([userId])
  @@map("patient_profiles")
}

model PatientAssessment {
  id            String   @id @default(uuid())
  patientId     String
  type          String
  answers       Int[]
  totalScore    Int
  severityLevel String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@map("patient_assessments")
}

model PatientMoodEntry {
  id        String   @id @default(uuid())
  patientId String
  moodScore Int
  note      String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date])
  @@map("patient_mood_entries")
}

// ============ PATIENT RESPONSES ============

model PatientSessionResponse {
  id         String @id @default(uuid())
  sessionId  String
  patientId  String
  questionId String

  // Response data (flexible to support all question types)
  // MULTIPLE_CHOICE: { selectedOptionId: "abc123" }
  // TEXT: { text: "Patient's response" }
  // SLIDER: { value: 7, min: 0, max: 10 }
  // CHECKBOX: { selectedOptions: ["opt1", "opt2"] }
  responseData Json

  // Timing
  timeSpentSeconds  Int? // Time spent on this question
  answeredAt        DateTime  @default(now())
  // Message acknowledgement fields
  messageId         String?   @unique
  deliveredToStream Boolean   @default(false)
  acknowledgedAt    DateTime?
  retryCount        Int       @default(0)

  // Related response for follow-ups
  previousResponseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session           PatientSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  patient           User                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  question          CBTQuestion              @relation(fields: [questionId], references: [id], onDelete: Restrict)
  previousResponse  PatientSessionResponse?  @relation("FollowUpResponse", fields: [previousResponseId], references: [id], onDelete: SetNull)
  followUpResponses PatientSessionResponse[] @relation("FollowUpResponse")

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@index([patientId])
  @@index([questionId])
  @@index([answeredAt])
  @@index([sessionId, patientId])
  @@map("patient_session_responses")
}

// ============ RESPONSE ANALYTICS ============

model PatientResponse {
  id         String @id @default(uuid())
  questionId String

  // Aggregated response data
  // { multipleChoice: { optionId: count }, text: { ... }, slider: { average, min, max } }
  responseStats  Json
  totalResponses Int  @default(0)

  updatedAt DateTime @updatedAt

  // Relations
  question CBTQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId])
  @@index([questionId])
  @@map("patient_responses")
}

// ============ SESSION EXPORTS ============

model SessionExport {
  id        String  @id @default(uuid())
  sessionId String
  jobId     String? @unique
  format    String // "PDF" | "CSV" | "JSON"
  fileName  String
  filePath  String? // S3 path or local path
  fileSize  Int?

  // Export status
  status       String  @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED"
  errorMessage String?

  createdAt DateTime  @default(now())
  expiresAt DateTime? // For temporary files

  jobCreatedAt DateTime? @default(now())

  // Relations
  session PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
  @@map("session_exports")
}

// ============ THERAPY BOOKINGS (calendar/booking system) ============

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model TherapySession {
  id                 String        @id @default(uuid())
  bookingReferenceId String        @unique
  patientProfileId   String
  therapistProfileId String
  dateTime           DateTime
  durationMinutes    Int           @default(50)
  sessionFeeMinor    BigInt        @default(0)
  paymentStatus      String        @default("UNPAID")
  agoraChannel       String?
  agoraToken         String?
  status             BookingStatus @default(PENDING)

  // Encrypted therapist note (optional)
  noteEncryptedContent     String?
  noteIv                   String?
  noteAuthTag              String?
  noteUpdatedAt            DateTime?
  noteUpdatedByTherapistId String?

  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  therapistProfile User           @relation(fields: [therapistProfileId], references: [id], onDelete: Cascade)

  @@index([therapistProfileId, dateTime])
  @@index([patientProfileId, dateTime])
  @@map("therapy_sessions")
}

model SessionBookingIntent {
  id             String             @id @default(uuid())
  patientId      String
  providerId     String
  scheduledAt    DateTime
  durationMinute Int                @default(50)
  amountMinor    BigInt
  currency       String             @default("INR")
  razorpayOrderId String            @unique
  razorpayPaymentId String?
  status         BookingIntentStatus @default(PENDING)
  sessionId      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  patient  User @relation("BookingIntentPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider User @relation("BookingIntentProvider", fields: [providerId], references: [id], onDelete: Restrict)

  @@index([patientId, status, createdAt])
  @@index([providerId, scheduledAt])
  @@index([scheduledAt])
  @@map("session_booking_intents")
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_conversations")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  message     String
  payload     Json?
  isRead      Boolean  @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([scheduledAt])
  @@map("notifications")
}

// ============ SESSION TEMPLATES LIBRARY ============

model SessionTemplateLibrary {
  id         String   @id @default(uuid())
  templateId String
  category   String // "Public" | "Organization" | "Private"
  tags       String[] // ["anxiety", "cbt", "beginner"]
  ratings    Int? // Average rating
  downloads  Int      @default(0)
  isApproved Boolean  @default(false)
  approvedBy String? // Admin user ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template CBTSessionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId])
  @@index([category])
  @@index([isApproved])
  @@map("session_template_library")
}

// ============ AUDIT & COMPLIANCE ============

model SessionAuditLog {
  id         String  @id @default(cuid())
  sessionId  String?
  userId     String?
  action     String // "CREATED", "UPDATED", "DELETED", "PUBLISHED"
  entityType String // "SESSION_TEMPLATE", "PATIENT_SESSION", "RESPONSE"
  entityId   String
  changes    Json? // Diff of what changed
  ipAddress  String?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("session_audit_logs")
}

// ============ PRESENCE TRACKING ============

model SessionPresence {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  role        UserRole
  status      String   @default("OFFLINE")
  lastSeenAt  DateTime @default(now())
  clientCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([sessionId, userId, role])
  @@index([sessionId])
  @@index([userId])
  @@map("session_presence")
}

// Export logs for audit trail when therapists export session data
model ExportLog {
  id          String   @id @default(cuid())
  therapistId String
  sessionId   String
  exportType  String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([therapistId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("export_logs")
}

enum FinancialSessionStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum FinancialPaymentStatus {
  INITIATED
  PENDING_CAPTURE
  CAPTURED
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

enum WalletTxnType {
  CREDIT_PENDING
  RELEASE
  DEBIT_PAYOUT
  REVERSAL
  ADJUSTMENT
}

enum WalletTxnStatus {
  POSTED
  VOIDED
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
  FAILED
}

enum RevenueType {
  SESSION
  SUBSCRIPTION
  CONTENT
}

enum SubscriptionDomain {
  PATIENT
  PROVIDER
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  LEAD_PLAN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum WebhookProvider {
  RAZORPAY
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  SKIPPED_DUPLICATE
  FAILED
}

enum FinancialAuditActorType {
  SYSTEM
  ADMIN
  WEBHOOK
  CRON
}

enum LeadStatus {
  AVAILABLE
  PURCHASED
  EXPIRED
  NO_RESPONSE
  ACCEPTED
}

enum LeadPaymentStatus {
  NOT_REQUIRED
  INITIATED
  CAPTURED
  FAILED
}

model FinancialSession {
  id                  String                 @id @default(uuid())
  patientId           String
  providerId          String
  status              FinancialSessionStatus @default(PENDING_PAYMENT)
  expectedAmountMinor BigInt
  currency            String                 @default("INR")
  idempotencyKey      String                 @unique
  razorpayOrderId     String?                @unique
  confirmedAt         DateTime?
  completedAt         DateTime?
  expiredAt           DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  patient            User                @relation("FinancialPatient", fields: [patientId], references: [id], onDelete: Restrict)
  provider           User                @relation("FinancialProvider", fields: [providerId], references: [id], onDelete: Restrict)
  payments           FinancialPayment[]  @relation("SessionPayments")
  walletTransactions WalletTransaction[] @relation("SessionWalletTransactions")
  revenueLedger      RevenueLedger[]     @relation("SessionRevenueLedger")

  @@index([patientId, status])
  @@index([providerId, status])
  @@index([createdAt])
  @@map("financial_sessions")
}

model Lead {
  id                      String     @id @default(uuid())
  patientId               String
  providerId              String?
  status                  LeadStatus @default(AVAILABLE)
  matchScore              Int?
  amountMinor             BigInt
  currency                String     @default("INR")
  previewData             Json?
  patientAcceptanceUntil  DateTime?
  providerContactedAt     DateTime?
  purchasedAt             DateTime?
  acceptedAt              DateTime?
  expiresAt               DateTime?
  paymentStatus           LeadPaymentStatus @default(NOT_REQUIRED)
  razorpayOrderId         String?           @unique
  razorpayPaymentId       String?           @unique
  paymentCapturedAt       DateTime?
  idempotencyKey          String?    @unique
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  patient  User  @relation("LeadPatient", fields: [patientId], references: [id], onDelete: Restrict)
  provider User? @relation("LeadProvider", fields: [providerId], references: [id], onDelete: Restrict)

  @@index([status, createdAt(sort: Desc)])
  @@index([providerId, status])
  @@index([providerId, paymentStatus])
  @@index([patientId, status])
  @@index([patientAcceptanceUntil])
  @@map("leads")
}

model FinancialPayment {
  id                    String                 @id @default(uuid())
  sessionId             String
  providerId            String
  providerGateway       String                 @default("RAZORPAY")
  razorpayOrderId       String                 @unique
  razorpayPaymentId     String?                @unique
  status                FinancialPaymentStatus @default(INITIATED)
  amountMinor           BigInt
  currency              String                 @default("INR")
  therapistShareMinor   BigInt                 @default(0)
  platformShareMinor    BigInt                 @default(0)
  captureIdempotencyKey String?                @unique
  capturedAt            DateTime?
  failedAt              DateTime?
  failureReason         String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  session            FinancialSession    @relation("SessionPayments", fields: [sessionId], references: [id], onDelete: Restrict)
  wallet             ProviderWallet      @relation("WalletPayments", fields: [providerId], references: [providerId], onDelete: Restrict)
  revenueLedger      RevenueLedger[]     @relation("PaymentRevenueLedger")
  walletTransactions WalletTransaction[] @relation("PaymentWalletTransactions")

  @@index([sessionId, status])
  @@index([providerId, status])
  @@index([razorpayOrderId])
  @@index([createdAt])
  @@map("financial_payments")
}

model ProviderWallet {
  providerId            String    @id
  pendingBalanceMinor   BigInt    @default(0)
  availableBalanceMinor BigInt    @default(0)
  lifetimeEarningsMinor BigInt    @default(0)
  isFrozen              Boolean   @default(false)
  frozenReason          String?
  frozenAt              DateTime?
  version               Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  provider     User                @relation("ProviderWalletOwner", fields: [providerId], references: [id], onDelete: Restrict)
  transactions WalletTransaction[] @relation("WalletTransactions")
  payouts      PayoutRequest[]     @relation("WalletPayouts")
  payments     FinancialPayment[]  @relation("WalletPayments")

  @@index([isFrozen])
  @@index([updatedAt])
  @@map("provider_wallets")
}

model WalletTransaction {
  id                 String          @id @default(uuid())
  providerId         String
  walletTxnType      WalletTxnType
  status             WalletTxnStatus @default(POSTED)
  amountMinor        BigInt
  currency           String          @default("INR")
  balanceBeforeMinor BigInt
  balanceAfterMinor  BigInt
  sessionId          String?
  paymentId          String?
  payoutRequestId    String?
  revenueLedgerId    String?
  referenceKey       String?         @unique
  metadata           Json?
  createdAt          DateTime        @default(now())

  wallet  ProviderWallet    @relation("WalletTransactions", fields: [providerId], references: [providerId], onDelete: Restrict)
  session FinancialSession? @relation("SessionWalletTransactions", fields: [sessionId], references: [id], onDelete: Restrict)
  payment FinancialPayment? @relation("PaymentWalletTransactions", fields: [paymentId], references: [id], onDelete: Restrict)
  payout  PayoutRequest?    @relation("PayoutWalletTransactions", fields: [payoutRequestId], references: [id], onDelete: Restrict)
  revenue RevenueLedger?    @relation("RevenueWalletTransactions", fields: [revenueLedgerId], references: [id], onDelete: Restrict)

  @@index([providerId, createdAt(sort: Desc)])
  @@index([walletTxnType, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([paymentId])
  @@index([payoutRequestId])
  @@map("wallet_transactions")
}

model PayoutRequest {
  id                     String       @id @default(uuid())
  providerId             String
  amountMinor            BigInt
  currency               String       @default("INR")
  status                 PayoutStatus @default(REQUESTED)
  minWithdrawalRuleMinor BigInt       @default(10000)
  requestedAt            DateTime     @default(now())
  approvedAt             DateTime?
  paidAt                 DateTime?
  rejectedAt             DateTime?
  approvedByAdminId      String?
  rejectedByAdminId      String?
  rejectionReason        String?
  bankReference          String?      @unique
  idempotencyKey         String       @unique

  provider           ProviderWallet      @relation("WalletPayouts", fields: [providerId], references: [providerId], onDelete: Restrict)
  walletTransactions WalletTransaction[] @relation("PayoutWalletTransactions")

  @@index([providerId, status, requestedAt(sort: Desc)])
  @@index([status, requestedAt(sort: Desc)])
  @@map("payout_requests")
}

model MarketplaceSubscription {
  id                     String             @id @default(uuid())
  userId                 String
  domain                 SubscriptionDomain
  plan                   SubscriptionPlan
  status                 SubscriptionStatus @default(PAST_DUE)
  providerGateway        String             @default("RAZORPAY")
  razorpaySubscriptionId String             @unique
  razorpayPlanId         String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  nextBillingDate        DateTime?
  cancelledAt            DateTime?
  expiredAt              DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user          User                  @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Restrict)
  invoices      SubscriptionInvoice[] @relation("SubscriptionInvoices")
  revenueLedger RevenueLedger[]       @relation("SubscriptionRevenueLedger")

  @@index([userId, domain, status])
  @@index([status, nextBillingDate])
  @@index([createdAt])
  @@map("marketplace_subscriptions")
}

model SubscriptionInvoice {
  id                String    @id @default(uuid())
  subscriptionId    String
  razorpayPaymentId String?   @unique
  amountMinor       BigInt
  currency          String    @default("INR")
  billedAt          DateTime
  nextBillingDate   DateTime?
  createdAt         DateTime  @default(now())

  subscription MarketplaceSubscription @relation("SubscriptionInvoices", fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId, billedAt(sort: Desc)])
  @@map("subscription_invoices")
}

model PatientSubscription {
  id           String   @id @default(uuid())
  userId       String   @unique
  planName     String
  price        Int
  billingCycle String
  status       String
  autoRenew    Boolean  @default(true)
  renewalDate  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("patient_subscriptions")
}

model PatientPaymentMethod {
  id          String   @id @default(uuid())
  userId      String   @unique
  cardLast4   String
  cardBrand   String
  expiryMonth Int
  expiryYear  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_payment_methods")
}

model PatientInvoice {
  id         String   @id @default(uuid())
  userId     String
  amount     Int
  status     String
  invoiceUrl String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("patient_invoices")
}

model PatientExercise {
  id         String   @id @default(uuid())
  patientId  String
  title      String
  assignedBy String
  duration   Int
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // NOTE: assignedBy is currently mock therapist reference.
  // Replace with real therapist relation once therapist module is built.
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@map("patient_exercises")
}

model PatientProgress {
  id                 String   @id @default(uuid())
  patientId          String   @unique
  sessionsCompleted  Int      @default(0)
  totalSessions      Int      @default(0)
  exercisesCompleted Int      @default(0)
  totalExercises     Int      @default(0)
  phqStart           Int?
  phqCurrent         Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_progress")
}

model RevenueLedger {
  id                      String      @id @default(uuid())
  type                    RevenueType
  grossAmountMinor        BigInt
  platformCommissionMinor BigInt
  providerShareMinor      BigInt
  taxAmountMinor          BigInt      @default(0)
  currency                String      @default("INR")
  referenceId             String
  paymentId               String?
  sessionId               String?
  subscriptionId          String?
  createdAt               DateTime    @default(now())

  payment            FinancialPayment?        @relation("PaymentRevenueLedger", fields: [paymentId], references: [id], onDelete: Restrict)
  session            FinancialSession?        @relation("SessionRevenueLedger", fields: [sessionId], references: [id], onDelete: Restrict)
  subscription       MarketplaceSubscription? @relation("SubscriptionRevenueLedger", fields: [subscriptionId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]      @relation("RevenueWalletTransactions")

  @@index([type, createdAt(sort: Desc)])
  @@index([referenceId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([subscriptionId])
  @@map("revenue_ledger")
}

model WebhookLog {
  id               String               @id @default(uuid())
  provider         WebhookProvider      @default(RAZORPAY)
  eventId          String
  eventType        String
  payloadHash      String
  signature        String
  isSignatureValid Boolean
  processStatus    WebhookProcessStatus @default(RECEIVED)
  firstSeenAt      DateTime             @default(now())
  processedAt      DateTime?
  errorMessage     String?
  sessionId        String?
  subscriptionId   String?
  rawPayload       Json

  @@unique([provider, eventId])
  @@index([eventType, processStatus])
  @@index([firstSeenAt])
  @@map("webhook_logs")
}

model FinancialAuditLog {
  id         String                  @id @default(uuid())
  actorType  FinancialAuditActorType
  actorId    String?
  action     String
  entityType String
  entityId   String
  reason     String?
  beforeJson Json?
  afterJson  Json?
  traceId    String?
  createdAt  DateTime                @default(now())

  actor User? @relation("UserFinancialAudits", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorType, createdAt(sort: Desc)])
  @@index([traceId])
  @@map("financial_audit_logs")
}

model Certification {
  id                 String             @id @default(uuid())
  slug               String             @unique
  code               String             @unique
  title              String
  shortTitle         String?
  subtitle           String
  level              CertificationLevel
  levelBadge         String
  journeyDescription String
  durationLabel      String
  investmentLabel    String
  monthlyIncomeLabel String?
  modulesCount       Int?
  deliveryMode       String?
  sessionRateLabel   String?
  outcomeLabel       String?
  prerequisitesLabel String
  primaryCtaLabel    String
  secondaryCtaLabel  String             @default("Learn More")
  isInvitationOnly   Boolean            @default(false)
  enrollmentOpen     Boolean            @default(true)
  sortOrder          Int                @default(100)
  isActive           Boolean            @default(true)
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([level, sortOrder])
  @@index([isActive, sortOrder])
  @@map("certifications")
}
