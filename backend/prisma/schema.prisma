  patient            User                @relation("FinancialPatient", fields: [patientId], references: [id], onDelete: Restrict)
  provider           User                @relation("FinancialProvider", fields: [providerId], references: [id], onDelete: Restrict)
  payments           FinancialPayment[]  @relation("SessionPayments")
  walletTransactions WalletTransaction[] @relation("SessionWalletTransactions")
  revenueLedger      RevenueLedger[]     @relation("SessionRevenueLedger")

  @@index([patientId, status])
  @@index([providerId, status])
  @@index([createdAt])
