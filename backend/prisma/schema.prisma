generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  PATIENT
  THERAPIST
  PSYCHOLOGIST
  PSYCHIATRIST
  COACH
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
  DELETED
}

enum ProviderType {
  THERAPIST
  PSYCHOLOGIST
  COACH
  PSYCHIATRIST
}

enum SessionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DEPRECATED
}

enum UserProvider {
  LOCAL
  GOOGLE
  PHONE
}

enum CertificationLevel {
  ENTRY
  PROFESSIONAL
  MASTERY
}

enum ScreeningTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ScreeningAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum ProviderExtraQuestionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RegistrationType {
  RCI
  NMC
  STATE_COUNCIL
  OTHER
}

enum OnboardingStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum ProviderDocumentType {
  DEGREE
  ID_PROOF
  LICENSE
}

// ============ USERS ============

model User {
  id                            String        @id @default(uuid())
  name                          String?
  email                         String?       @unique
  phone                         String?       @unique
  firstName                     String        @default("")
  lastName                      String        @default("")
  role                          UserRole
  providerType                  ProviderType? @map("provider_type")
  companyId                     String?       @map("company_id")
  status                        UserStatus    @default(ACTIVE)
  provider                      UserProvider  @default(LOCAL)
  passwordHash                  String?
  googleId                      String?       @unique
  profileImageKey               String?
  profileImageUrl               String?
  showNameToProviders           Boolean       @default(true)
  emailVerified                 Boolean       @default(false)
  phoneVerified                 Boolean       @default(false)
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  phoneVerificationOtpHash      String?
  phoneVerificationOtpExpiresAt DateTime?
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  mfaEnabled                    Boolean       @default(false)
  mfaSecret                     String?
  failedLoginAttempts           Int           @default(0)
  lockUntil                     DateTime?
  lastLoginAt                   DateTime?
  passwordChangedAt             DateTime?
  isTherapistVerified           Boolean       @default(false)
  therapistVerifiedAt           DateTime?
  therapistVerifiedByUserId     String?
  onboardingStatus              OnboardingStatus?
  isDeleted                     Boolean       @default(false)
  deletedAt                     DateTime?
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt

  // Relations
  patientProfile                PatientProfile?
  therapyBookings               TherapySession[]
  financialPatientSessions      FinancialSession[]          @relation("FinancialPatient")
  financialProviderSessions     FinancialSession[]          @relation("FinancialProvider")
  patientLeads                  Lead[]                      @relation("LeadPatient")
  providerLeads                 Lead[]                      @relation("LeadProvider")
  providerWallet                ProviderWallet?             @relation("ProviderWalletOwner")
  subscriptions                 MarketplaceSubscription[]   @relation("UserSubscriptions")
  financialAuditEvents          FinancialAuditLog[]         @relation("UserFinancialAudits")
  authSessions                  AuthSession[]
  authAuditLogs                 AuthAuditLog[]
  aiConversations               AIConversation[]
  chatMessages                  ChatMessage[]
  phq9Assessments               PHQ9Assessment[]            @relation("UserPHQ9Assessments")
  gad7Assessments               GAD7Assessment[]            @relation("UserGAD7Assessments")
  riskScores                    RiskScore[]                 @relation("UserRiskScores")
  crisisEscalations             CrisisEscalation[]          @relation("UserCrisisEscalations")
  moodLogs                      MoodLog[]                   @relation("UserMoodLogs")
  chatAnalyses                  ChatAnalysis[]              @relation("UserChatAnalyses")
  moodPredictions               MoodPrediction[]            @relation("UserMoodPredictions")
  notifications                 Notification[]
  bookingIntentsAsPatient       SessionBookingIntent[]      @relation("BookingIntentPatient")
  bookingIntentsAsProvider      SessionBookingIntent[]      @relation("BookingIntentProvider")
  appointmentRequestsAsPatient  AppointmentRequest[]        @relation("AppointmentRequestPatient")
  appointmentRequestsAccepted   AppointmentRequest[]        @relation("AppointmentRequestAcceptedProvider")
  patientSubscription           PatientSubscription?
  patientPaymentMethod          PatientPaymentMethod?
  patientInvoices               PatientInvoice[]
  therapistSessionNotesAuthored TherapistSessionNote[]      @relation("TherapistSessionNoteAuthor")
  therapistExercises            TherapistExercise[]
  therapistAssessments          TherapistAssessmentRecord[]
  therapistResources            TherapistResource[]
  therapistCareTeamMembers      TherapistCareTeamMember[]
  therapistProfile              TherapistProfile?
  userCapabilities              UserCapability[]            @relation("UserCapabilitiesOwner")
  grantedCapabilities           UserCapability[]            @relation("UserCapabilitiesGrantor")
  careTeamAssignmentsAsPatient  CareTeamAssignment[]        @relation("CareTeamAssignmentPatient")
  careTeamAssignmentsAsProvider CareTeamAssignment[]        @relation("CareTeamAssignmentProvider")
  careTeamAssignmentsCreated    CareTeamAssignment[]        @relation("CareTeamAssignmentCreator")
  providerExtraQuestionsCreated ProviderExtraQuestion[]
  consents                      Consent[]
  consentRevocations            Consent[]                   @relation("ConsentRevokedByUser")
  auditEventsAsActor            AuditEvent[]                @relation("AuditEventsActor")
  tenantPoliciesUpdated         TenantPolicy[]              @relation("TenantPolicyUpdatedBy")
  therapyPlans                  TherapyPlan[]               @relation("TherapistPlans")
  directConversationsAsPatient  DirectConversation[]         @relation("DirectConversationPatient")
  directConversationsAsProvider DirectConversation[]         @relation("DirectConversationProvider")
  directMessagesSent            DirectMessage[]              @relation("DirectMessageSender")
  prescriptionsAsPatient        Prescription[]               @relation("PrescriptionPatient")
  prescriptionsAsProvider       Prescription[]               @relation("PrescriptionProvider")
  labOrdersAsPatient            LabOrder[]                   @relation("LabOrderPatient")
  labOrdersAsProvider           LabOrder[]                   @relation("LabOrderProvider")
  goalsAsPatient                Goal[]                       @relation("GoalPatient")
  goalsAsProvider               Goal[]                       @relation("GoalProvider")
  providerDocumentsUploaded     ProviderDocument[]
  dailyCheckIns                 DailyCheckIn[]               @relation("UserDailyCheckIns")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([providerType])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([isDeleted])
  @@map("users")
}

model UserCapability {
  id          String    @id @default(uuid())
  userId      String
  capability  String
  source      String    @default("effective")
  isEffective Boolean   @default(true)
  grantedById String?
  computedAt  DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User  @relation("UserCapabilitiesOwner", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("UserCapabilitiesGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, capability])
  @@index([capability, isEffective])
  @@index([computedAt])
  @@map("user_capabilities")
}

model CareTeamAssignment {
  id           String    @id @default(uuid())
  patientId    String
  providerId   String
  assignedById String?
  accessScope  Json
  status       String    @default("ACTIVE")
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient    User  @relation("CareTeamAssignmentPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider   User  @relation("CareTeamAssignmentProvider", fields: [providerId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("CareTeamAssignmentCreator", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([patientId, providerId])
  @@index([providerId, status])
  @@index([assignedAt])
  @@map("care_team_assignments")
}

model Consent {
  id          String    @id @default(uuid())
  userId      String
  consentType String
  purpose     String
  artifactRef String?
  status      String    @default("GRANTED")
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  revokedById String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedBy User? @relation("ConsentRevokedByUser", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([userId, consentType, status])
  @@index([grantedAt])
  @@map("consents")
}

model AuditEvent {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  tenantId   String?
  scope      String
  action     String
  entityType String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  userAgent  String?
  traceId    String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditEventsActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, scope, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([traceId])
  @@map("audit_events")
}

model TenantPolicy {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  privacyPolicy Json
  featureFlags  Json
  policyVersion Int      @default(1)
  updatedById   String?
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  updatedBy User? @relation("TenantPolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([effectiveFrom])
  @@map("tenant_policies")
}

enum BookingIntentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum AppointmentRequestStatus {
  PENDING
  ACCEPTED_BY_PROVIDER
  PAYMENT_PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
  REJECTED_BY_ALL
}

enum ProviderRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  jti              String    @unique
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  device           String?
  revokedAt        DateTime?
  expiresAt        DateTime
  lastActiveAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  status    String
  email     String?
  phone     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

// ============ PATIENT PROFILES & HEALTH RECORDS ============

model PatientProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  age              Int
  gender           String
  medicalHistory   String?
  emergencyContact Json
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user                         User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments                  PatientAssessment[]
  moodEntries                  PatientMoodEntry[]
  therapySessions              TherapySession[]
  exercises                    PatientExercise[]
  progress                     PatientProgress?
  therapistSessionNotes        TherapistSessionNote[]
  therapistExercisesAssigned   TherapistExercise[]
  therapistAssessmentsAssigned TherapistAssessmentRecord[]
  therapistResourcesAssigned   TherapistResource[]
  therapistCareTeamMembers     TherapistCareTeamMember[]
  screeningAttempts            ScreeningAttempt[]
  providerQuestionAssignments  ProviderQuestionAssignment[]
  TherapyPlan                  TherapyPlan[]

  @@index([userId])
  @@map("patient_profiles")
}

// Therapist profile stored separately for therapist-specific metadata
model TherapistProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  displayName       String
  professionalType  String?
  registrationType  RegistrationType?
  registrationNum   String?   @unique
  contactEmail      String?
  education         String?
  highestQual       String?
  licenseRci        String?
  licenseNmc        String?
  bio               String?
  clinicalCategories String[] @default([])
  specializations   String[]  @default([])
  languages         String[]  @default([])
  corporateReady    Boolean   @default(false)
  shiftPreferences  String[]  @default([])
  yearsExperience   Int?      @default(0)
  yearsOfExperience Int?      @default(0)
  hourlyRate        Int?      @default(0)
  consultationFee   Int?      @default(0) // in minor units
  bankDetails       Json?
  tagline           String?
  digitalSignature  String?
  onboardingCompleted Boolean @default(false)
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  verifiedByUserId  String?
  availability      Json? // array of slots { dayOfWeek, startMinute, endMinute, isAvailable }
  averageRating     Float?    @default(0)
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         ProviderDocument[]

  @@index([userId])
  @@map("therapist_profiles")
}

model ProviderDocument {
  id                String               @id @default(uuid())
  providerProfileId String
  userId            String
  documentType      ProviderDocumentType
  url               String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  providerProfile TherapistProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, documentType])
  @@index([userId, documentType])
  @@map("provider_documents")
}

model PatientAssessment {
  id            String   @id @default(uuid())
  patientId     String
  type          String
  answers       Int[]
  totalScore    Int
  severityLevel String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@map("patient_assessments")
}

model ScreeningTemplate {
  id               String                  @id @default(uuid())
  key              String                  @unique
  title            String
  description      String?
  estimatedMinutes Int                     @default(3)
  isPublic         Boolean                 @default(true)
  randomizeOrder   Boolean                 @default(true)
  status           ScreeningTemplateStatus @default(DRAFT)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  questions    ScreeningQuestion[]
  scoringBands ScreeningScoringBand[]
  attempts     ScreeningAttempt[]

  @@index([key, status])
  @@map("screening_templates")
}

model ScreeningQuestion {
  id         String   @id @default(uuid())
  templateId String
  prompt     String
  sectionKey String   @default("general")
  orderIndex Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template                           ScreeningTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  options                            ScreeningQuestionOption[]
  answers                            ScreeningAnswer[]
  providerExtraQuestionsFromTemplate ProviderExtraQuestion[]

  @@unique([templateId, orderIndex])
  @@index([templateId, isActive])
  @@map("screening_questions")
}

model ScreeningQuestionOption {
  id          String   @id @default(uuid())
  questionId  String
  label       String
  optionIndex Int
  points      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question                 ScreeningQuestion             @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers                  ScreeningAnswer[]
  providerExtraOptionLinks ProviderExtraQuestionOption[]

  @@unique([questionId, optionIndex])
  @@index([questionId])
  @@map("screening_question_options")
}

model ScreeningScoringBand {
  id             String   @id @default(uuid())
  templateId     String
  minScore       Int
  maxScore       Int
  severity       String
  interpretation String
  recommendation String
  actionLabel    String
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  template ScreeningTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, orderIndex])
  @@index([templateId, minScore, maxScore])
  @@map("screening_scoring_bands")
}

model ScreeningAttempt {
  id              String                 @id @default(uuid())
  templateId      String
  patientId       String?
  accessTokenHash String?
  status          ScreeningAttemptStatus @default(IN_PROGRESS)
  attemptSeed     Int
  presentedOrder  Json
  totalScore      Int?
  severityLevel   String?
  interpretation  String?
  recommendation  String?
  actionLabel     String?
  startedAt       DateTime               @default(now())
  submittedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  template            ScreeningTemplate            @relation(fields: [templateId], references: [id], onDelete: Restrict)
  patient             PatientProfile?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  answers             ScreeningAnswer[]
  providerAssignments ProviderQuestionAssignment[]

  @@index([templateId, status])
  @@index([patientId, createdAt])
  @@map("screening_attempts")
}

model ScreeningAnswer {
  id          String   @id @default(uuid())
  attemptId   String
  questionId  String
  optionId    String
  optionIndex Int
  points      Int
  createdAt   DateTime @default(now())

  attempt  ScreeningAttempt        @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ScreeningQuestion       @relation(fields: [questionId], references: [id], onDelete: Restrict)
  option   ScreeningQuestionOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("screening_answers")
}

model ProviderExtraQuestion {
  id                 String                      @id @default(uuid())
  providerId         String
  templateQuestionId String?
  prompt             String
  sectionKey         String                      @default("provider-extra")
  isRequired         Boolean                     @default(false)
  status             ProviderExtraQuestionStatus @default(DRAFT)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  provider         User                          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  templateQuestion ScreeningQuestion?            @relation(fields: [templateQuestionId], references: [id], onDelete: SetNull)
  options          ProviderExtraQuestionOption[]
  assignments      ProviderQuestionAssignment[]

  @@index([providerId, status])
  @@map("provider_extra_questions")
}

model ProviderExtraQuestionOption {
  id               String   @id @default(uuid())
  questionId       String
  label            String
  optionIndex      Int
  points           Int
  templateOptionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  question              ProviderExtraQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  templateOption        ScreeningQuestionOption?     @relation(fields: [templateOptionId], references: [id], onDelete: SetNull)
  selectedInAssignments ProviderQuestionAssignment[]

  @@unique([questionId, optionIndex])
  @@index([questionId])
  @@map("provider_extra_question_options")
}

model ProviderQuestionAssignment {
  id                 String    @id @default(uuid())
  providerQuestionId String
  patientId          String
  attemptId          String?
  isActive           Boolean   @default(true)
  assignedAt         DateTime  @default(now())
  expiresAt          DateTime?
  selectedOptionId   String?
  patientNotes       String?
  answeredAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  providerQuestion ProviderExtraQuestion        @relation(fields: [providerQuestionId], references: [id], onDelete: Cascade)
  patient          PatientProfile               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  attempt          ScreeningAttempt?            @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  selectedOption   ProviderExtraQuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([patientId, isActive])
  @@index([providerQuestionId])
  @@index([attemptId])
  @@map("provider_question_assignments")
}

model PatientMoodEntry {
  id        String   @id @default(uuid())
  patientId String
  moodScore Int
  note      String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date])
  @@map("patient_mood_entries")
}

// ============ RESPONSE ANALYTICS ============

// ============ SESSION EXPORTS ============

// ============ THERAPY BOOKINGS (calendar/booking system) ============

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model TherapySession {
  id                 String        @id @default(uuid())
  bookingReferenceId String        @unique
  patientProfileId   String
  therapistProfileId String
  meetingRoomName    String?       @map("meeting_room_name")
  dateTime           DateTime
  durationMinutes    Int           @default(50)
  isLocked           Boolean       @default(true)
  sessionFeeMinor    BigInt        @default(0)
  paymentStatus      String        @default("UNPAID")
  agoraChannel       String?
  agoraToken         String?
  status             BookingStatus @default(PENDING)
  transcript         String?
  audioRecordingUrl  String?       @map("audio_recording_url")

  // Encrypted therapist note (optional)
  noteEncryptedContent     String?
  noteIv                   String?
  noteAuthTag              String?
  noteUpdatedAt            DateTime?
  noteUpdatedByTherapistId String?

  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  patientProfile       PatientProfile        @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  therapistProfile     User                  @relation(fields: [therapistProfileId], references: [id], onDelete: Cascade)
  therapistSessionNote TherapistSessionNote?

  @@index([therapistProfileId, dateTime])
  @@index([patientProfileId, dateTime])
  @@map("therapy_sessions")
}

model TherapistSessionNote {
  id               String    @id @default(uuid())
  sessionId        String    @unique @map("session_id")
  therapistId      String    @map("therapist_id")
  patientId        String    @map("patient_id")
  sessionType      String    @default("Therapy Session") @map("session_type")
  subjective       String    @default("")
  objective        String    @default("")
  assessment       String    @default("")
  plan             String    @default("")
  phq9             Int?
  gad7             Int?
  assignedExercise String?   @map("assigned_exercise")
  nextSessionDate  DateTime? @map("next_session_date")
  status           String    @default("draft")
  history          Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  therapist User           @relation("TherapistSessionNoteAuthor", fields: [therapistId], references: [id], onDelete: Cascade)
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([therapistId, updatedAt(sort: Desc)])
  @@index([patientId, updatedAt(sort: Desc)])
  @@map("therapist_session_notes")
}

model TherapistExercise {
  id             String   @id @default(uuid())
  therapistId    String   @map("therapist_id")
  patientId      String?  @map("patient_id")
  patientName    String?  @map("patient_name")
  name           String
  category       String
  worksheetUrl   String?  @map("worksheet_url")
  completionRate Int      @default(0) @map("completion_rate")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  therapist User            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([therapistId, updatedAt(sort: Desc)])
  @@index([patientId])
  @@map("therapist_exercises")
}

model TherapistAssessmentRecord {
  id          String   @id @default(uuid())
  therapistId String   @map("therapist_id")
  patientId   String?  @map("patient_id")
  patientName String   @map("patient_name")
  type        String
  score       Int
  assessedAt  DateTime @default(now()) @map("assessed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  therapist User            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([therapistId, assessedAt(sort: Desc)])
  @@index([patientId])
