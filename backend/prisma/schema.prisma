  contract_number   String   @unique
  pricing_model     String
  price_per_member  Float?
  max_members       Int?

  start_date        DateTime
  end_date          DateTime

  created_at        DateTime @default(now())

  @@index([entityId])
}

model AgreementSignatureLog {
  id          Int                    @id @default(autoincrement())
  agreement_id Int
  event_type  String
  actor_type  String
  actor_name  String
  event_data  Json?
  created_at  DateTime               @default(now())
  agreement   InstitutionalAgreement @relation(fields: [agreement_id], references: [id], onDelete: Cascade)

  @@index([agreement_id])
  @@index([event_type])
  @@map("agreement_signature_logs")
}

