model CorporateAgreementTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  content     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agreements  CorporateAgreement[]

  @@map("corporate_agreement_templates")
}

model CorporateAgreement {
  id          String   @id @default(uuid())
  templateId  String
  email       String
  value       String?
  status      String   @default("Draft")
  companyKey  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template    CorporateAgreementTemplate @relation(fields: [templateId], references: [id])

  @@map("corporate_agreements")
}
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                      @id @default(uuid())
  email                         String?                     @unique
  firstName                     String                      @default("")
  lastName                      String                      @default("")
  role                          UserRole
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  deletedAt                     DateTime?
  emailVerificationOtpExpiresAt DateTime?
  emailVerificationOtpHash      String?
  emailVerified                 Boolean                     @default(false)
  failedLoginAttempts           Int                         @default(0)
  googleId                      String?                     @unique
  isDeleted                     Boolean                     @default(false)
  lastLoginAt                   DateTime?
  lockUntil                     DateTime?
  mfaEnabled                    Boolean                     @default(false)
  mfaSecret                     String?
  name                          String?
  passwordChangedAt             DateTime?
  passwordHash                  String?
  passwordResetOtpExpiresAt     DateTime?
  passwordResetOtpHash          String?
  phone                         String?                     @unique
  phoneVerificationOtpExpiresAt DateTime?
  phoneVerificationOtpHash      String?
  phoneVerified                 Boolean                     @default(false)
  profileImageKey               String?
  profileImageUrl               String?
  provider                      UserProvider                @default(LOCAL)
  showNameToProviders           Boolean                     @default(true)
  isTherapistVerified           Boolean                     @default(false)
  therapistVerifiedAt           DateTime?
  therapistVerifiedByUserId     String?
  providerType                  ProviderType?               @map("provider_type")
  companyId                     String?                     @map("company_id")
  status                        UserStatus                  @default(ACTIVE)
  onboardingStatus              OnboardingStatus?
  companyKey                    String?                     @map("company_key")
  isCompanyAdmin                Boolean                     @default(false) @map("is_company_admin")
  permissions                   Json?                       @default("{}")
  aiConversations               AIConversation[]
  auditEventsAsActor            AuditEvent[]                @relation("AuditEventsActor")
  auditLogs                     AuditLog[]
  authAuditLogs                 AuthAuditLog[]
  authSessions                  AuthSession[]
  careTeamAssignmentsCreated    CareTeamAssignment[]        @relation("CareTeamAssignmentCreator")
  careTeamAssignmentsAsPatient  CareTeamAssignment[]        @relation("CareTeamAssignmentPatient")
  careTeamAssignmentsAsProvider CareTeamAssignment[]        @relation("CareTeamAssignmentProvider")
  chatAnalyses                  ChatAnalysis[]              @relation("UserChatAnalyses")
  chatMessages                  ChatMessage[]
  consentRevocations            Consent[]                   @relation("ConsentRevokedByUser")
  consents                      Consent[]
  crisisEscalations             CrisisEscalation[]          @relation("UserCrisisEscalations")
  financialAuditEvents          FinancialAuditLog[]         @relation("UserFinancialAudits")
  financialPatientSessions      FinancialSession[]          @relation("FinancialPatient")
  financialProviderSessions     FinancialSession[]          @relation("FinancialProvider")
  gad7Assessments               GAD7Assessment[]            @relation("UserGAD7Assessments")
  goalsAsPatient                Goal[]                      @relation("GoalPatient")
  goalsAsProvider               Goal[]                      @relation("GoalProvider")
  labOrdersAsPatient            LabOrder[]                  @relation("LabOrderPatient")
  labOrdersAsProvider           LabOrder[]                  @relation("LabOrderProvider")
  leadAssignments               LeadAssignment[]
  legalAcceptances              UserAcceptance[]
  legalDocumentsUpdated         LegalDocument[]             @relation("LegalDocumentUpdatedBy")
  patientLeads                  Lead[]                      @relation("LeadPatient")
  providerLeads                 Lead[]                      @relation("LeadProvider")
  subscriptions                 MarketplaceSubscription[]   @relation("UserSubscriptions")
  moodLogs                      MoodLog[]                   @relation("UserMoodLogs")
  moodPredictions               MoodPrediction[]            @relation("UserMoodPredictions")
  notifications                 Notification[]
  patientInvoices               PatientInvoice[]
  invoices                      Invoice[]                   @relation("UserInvoices")
  invoiceEventsAsActor          InvoiceEvent[]              @relation("InvoiceEventsActor")
  payouts                       Payout[]                    @relation("PayoutProvider")
  patient_pathway_state         patient_pathway_state?
  patientPaymentMethod          PatientPaymentMethod?
  patientProfile                PatientProfile?
  patientSubscription           PatientSubscription?
  phq9Assessments               PHQ9Assessment[]            @relation("UserPHQ9Assessments")
  platformAccess                PlatformAccess?
  platformConfigsUpdated        PlatformConfig[]           @relation("PlatformConfigUpdatedBy")
  prescriptionsAsPatient        Prescription[]              @relation("PrescriptionPatient")
  prescriptionsAsProvider       Prescription[]              @relation("PrescriptionProvider")
  providerExtraQuestionsCreated ProviderExtraQuestion[]
  providerSubscription          ProviderSubscription?
  providerWallet                ProviderWallet?             @relation("ProviderWalletOwner")
  qrCodesCreated                QrCode[]                    @relation("QrCodeCreatedBy")
  riskScores                    RiskScore[]                 @relation("UserRiskScores")
  bookingIntentsAsPatient       SessionBookingIntent[]      @relation("BookingIntentPatient")
  bookingIntentsAsProvider      SessionBookingIntent[]      @relation("BookingIntentProvider")
  tenantPoliciesUpdated         TenantPolicy[]              @relation("TenantPolicyUpdatedBy")
  therapistAssessments          TherapistAssessmentRecord[]
  therapistCareTeamMembers      TherapistCareTeamMember[]
  therapistExercises            TherapistExercise[]
  therapistProfile              TherapistProfile?
  therapistResources            TherapistResource[]
  therapistSessionNotesAuthored TherapistSessionNote[]      @relation("TherapistSessionNoteAuthor")
  therapyBookings               TherapySession[]
  groupTherapyRequests          GroupTherapySession[]       @relation("GroupTherapyRequestedBy")
  groupTherapyHostedSessions    GroupTherapySession[]       @relation("GroupTherapyHost")
  groupTherapyApprovedSessions  GroupTherapySession[]       @relation("GroupTherapyApprovedBy")
  groupTherapyInvitesSent       GroupTherapyInvite[]        @relation("GroupTherapyInviteBy")
  groupTherapyInvitesReceived   GroupTherapyInvite[]        @relation("GroupTherapyInvitePatient")
  grantedCapabilities           UserCapability[]            @relation("UserCapabilitiesGrantor")
  userCapabilities              UserCapability[]            @relation("UserCapabilitiesOwner")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([providerType])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([role, status])
  @@index([isDeleted])
  @@map("users")
}

model UserCapability {
  id          String    @id @default(uuid())
  userId      String
  capability  String
  source      String    @default("effective")
  isEffective Boolean   @default(true)
  grantedById String?
  computedAt  DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  grantedBy   User?     @relation("UserCapabilitiesGrantor", fields: [grantedById], references: [id])
  user        User      @relation("UserCapabilitiesOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, capability])
  @@index([capability, isEffective])
  @@index([computedAt])
  @@map("user_capabilities")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model QrCode {
  code            String   @id
  redirectUrl     String   @map("redirect_url")
  qrType          String?  @map("qr_type")
  destinationUrl  String?  @map("destination_url")
  ownerId         String?  @map("owner_id")
  isDynamic       Boolean  @default(true) @map("is_dynamic")
  expiresAt       DateTime? @map("expires_at")
  lastScannedAt   DateTime? @map("last_scanned_at")
  templateId      String   @default("classic-black") @map("template_id")
  stylePreset     String   @default("rounded") @map("style_preset")
  foregroundColor String   @default("#0F172A") @map("foreground_color")
  backgroundColor String   @default("#FFFFFF") @map("background_color")
  logoUrl         String?  @map("logo_url")
  isActive        Boolean  @default(true) @map("is_active")
  scanCount       Int      @default(0) @map("scan_count")
  connectedCount  Int      @default(0) @map("connected_count")
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       User?    @relation("QrCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  scans           QrScan[]
  conversions     QrConversion[]

  @@index([createdById])
  @@index([createdAt])
  @@index([qrType])
  @@index([ownerId])
  @@index([expiresAt])
  @@map("qr_codes")
}

model QrScan {
  id            String   @id @default(uuid())
  qrCodeCode    String   @map("qr_code_code")
  scanTimestamp DateTime @default(now()) @map("scan_timestamp")
  deviceType    String?  @map("device_type")
  deviceOs      String?  @map("device_os")
  ipAddress     String?  @map("ip_address")
  sessionId     String?  @map("session_id")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")
  qrCode        QrCode   @relation(fields: [qrCodeCode], references: [code], onDelete: Cascade)
  conversions   QrConversion[]

  @@index([qrCodeCode, scanTimestamp])
  @@index([sessionId])
  @@map("qr_scans")
}

model QrConversion {
  id                String   @id @default(uuid())
  qrCodeCode        String   @map("qr_code_code")
  qrScanId          String?  @map("qr_scan_id")
  sessionId         String?  @map("session_id")
  conversionType    String   @map("conversion_type")
  attributedRevenue Decimal  @default(0) @db.Decimal(10, 2) @map("attributed_revenue")
  conversionData    Json?    @map("conversion_data")
  conversionAt      DateTime @default(now()) @map("conversion_at")
  createdAt         DateTime @default(now()) @map("created_at")
  qrCode            QrCode   @relation(fields: [qrCodeCode], references: [code], onDelete: Cascade)
  qrScan            QrScan?  @relation(fields: [qrScanId], references: [id], onDelete: SetNull)

  @@index([qrCodeCode, conversionType])
  @@index([sessionId])
  @@index([conversionAt])
  @@map("qr_conversions")
}

model CareTeamAssignment {
  id           String    @id @default(uuid())
  patientId    String
  providerId   String
  assignedById String?
  accessScope  Json
  status       String    @default("ACTIVE")
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedBy   User?     @relation("CareTeamAssignmentCreator", fields: [assignedById], references: [id])
  patient      User      @relation("CareTeamAssignmentPatient", fields: [patientId], references: [id], onDelete: Cascade)
  provider     User      @relation("CareTeamAssignmentProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([patientId, providerId])
  @@index([providerId, status])
  @@index([assignedAt])
  @@map("care_team_assignments")
}

model Consent {
  id          String    @id @default(uuid())
  userId      String
  consentType String
  purpose     String
  artifactRef String?
  status      String    @default("GRANTED")
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  revokedById String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  revokedBy   User?     @relation("ConsentRevokedByUser", fields: [revokedById], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, status])
  @@index([grantedAt])
  @@map("consents")
}

model LegalDocument {
  id          String   @id @default(uuid())
  type        String
  version     Int
  title       String
  content     String
  isActive    Boolean  @default(false)
  publishedAt DateTime @default(now())
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("LegalDocumentUpdatedBy", fields: [updatedById], references: [id])
  acceptances UserAcceptance[]

  @@unique([type, version])
  @@index([type, isActive])
  @@index([publishedAt])
  @@map("legal_documents")
}

model UserAcceptance {
  id          String   @id @default(uuid())
  userId      String
  documentId  String
  documentVer Int
  acceptedAt  DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  source      String   @default("web")
  createdAt   DateTime @default(now())
  document    LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId, acceptedAt])
  @@index([documentId, acceptedAt])
  @@map("user_acceptances")
}

model AuditEvent {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  tenantId   String?
  scope      String
  action     String
  entityType String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  userAgent  String?
  traceId    String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditEventsActor", fields: [actorId], references: [id])

  @@index([tenantId, scope, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([traceId])
  @@map("audit_events")
}

model TenantPolicy {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  privacyPolicy Json
  featureFlags  Json
  policyVersion Int      @default(1)
  updatedById   String?
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  updatedBy     User?    @relation("TenantPolicyUpdatedBy", fields: [updatedById], references: [id])

  @@index([effectiveFrom])
  @@map("tenant_policies")
}

model PlatformConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  version     Int      @default(1)
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   User?    @relation("PlatformConfigUpdatedBy", fields: [updatedById], references: [id])

  @@index([key])
  @@map("platform_configs")
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  jti              String    @unique
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  device           String?
  revokedAt        DateTime?
  expiresAt        DateTime
  lastActiveAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  status    String
  email     String?
  phone     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

model ProviderVerification {
  id          String   @id @default(uuid())
  userId      String
  license     String
  licenseType String
  status      String
  checks      Json?
  flagReasons Json?
  verifiedAt  DateTime?
  reviewedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relation to `User` intentionally omitted to avoid adding inverse field on User model

  @@index([userId])
  @@map("provider_verifications")
}
 

model PatientProfile {
  id                           String                       @id @default(uuid())
  userId                       String                       @unique
  age                          Int
  gender                       String
  medicalHistory               String?
  emergencyContact             Json
  isDeleted                    Boolean                      @default(false)
  deletedAt                    DateTime?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  assessments                  PatientAssessment[]
  exercises                    PatientExercise[]
  moodEntries                  PatientMoodEntry[]
  user                         User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress                     PatientProgress?
  providerQuestionAssignments  ProviderQuestionAssignment[]
  screeningAttempts            ScreeningAttempt[]
  therapistAssessmentsAssigned TherapistAssessmentRecord[]
  therapistCareTeamMembers     TherapistCareTeamMember[]
  therapistExercisesAssigned   TherapistExercise[]
  therapistResourcesAssigned   TherapistResource[]
  therapistSessionNotes        TherapistSessionNote[]
  therapySessions              TherapySession[]

  @@index([userId])
  @@map("patient_profiles")
}

model TherapistProfile {
  id                  String            @id @default(uuid())
  userId              String            @unique
  displayName         String
  bio                 String?
  specializations     String[]          @default([])
  languages           String[]          @default([])
  yearsOfExperience   Int?              @default(0)
  consultationFee     Int?              @default(0)
  availability        Json?
  averageRating       Float?            @default(0)
  isDeleted           Boolean           @default(false)
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  registrationType    RegistrationType?
  highestQual         String?
  yearsExperience     Int?              @default(0)
  hourlyRate          Int?              @default(0)
  professionalType    String?
  registrationNum     String?
  contactEmail        String?
  education           String?
  licenseRci          String?
  licenseNmc          String?
  clinicalCategories  String[]          @default([])
  corporateReady      Boolean           @default(false)
  shiftPreferences    String[]          @default([])
  bankDetails         Json?
  tagline             String?
  digitalSignature    String?
  onboardingCompleted Boolean           @default(false)
  isVerified          Boolean           @default(false)
  verifiedAt          DateTime?
  verifiedByUserId    String?
  certifications           String[]            @default([])
  baseLatitude             Float?              @map("base_latitude")
  baseLongitude            Float?              @map("base_longitude")
  commissionOverride       Int?                @map("commission_override")
  rejectionReason          String?             @map("rejection_reason")
  certificationStatus      CertificationStatus @default(NONE)
  certificationCompletedAt DateTime?
  certificationPaymentId   String?
  leadBoostScore           Int                 @default(0)
  nriPoolCertified         Boolean             @default(false) @map("nri_pool_certified")
  nriPoolCertifiedAt       DateTime?           @map("nri_pool_certified_at")
  nriTimezoneShifts        String[]            @default([]) @map("nri_timezone_shifts")
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("therapist_profiles")
}

model ProviderDocument {
  id                String               @id @default(uuid())
  providerProfileId String
  userId            String
  documentType      ProviderDocumentType
  url               String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([providerProfileId, documentType])
  @@index([userId, documentType])
  @@map("provider_documents")
}

model PatientAssessment {
  id               String         @id @default(uuid())
  patientId        String
  type             String
  answers          Int[]
  totalScore       Int
  severityLevel    String
  entryType        String?
  sourceMetadata   String?
  utmCampaign      String?
  utmMedium        String?
  utmSource        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt(sort: Desc)])
  @@index([entryType, createdAt(sort: Desc)])
  @@map("patient_assessments")
}

model ScreeningTemplate {
  id               String                  @id @default(uuid())
  key              String                  @unique
  title            String
  description      String?
  estimatedMinutes Int                     @default(3)
  isPublic         Boolean                 @default(true)
  randomizeOrder   Boolean                 @default(true)
  status           ScreeningTemplateStatus @default(DRAFT)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  attempts         ScreeningAttempt[]
  questions        ScreeningQuestion[]
  scoringBands     ScreeningScoringBand[]

  @@index([key, status])
  @@map("screening_templates")
}

model GroupTherapySession {
  id          String  @id @default(cuid())
  title       String
  topic       String
  description String?
  sessionMode String  @map("session_mode")
  status      String

  requestedById   String  @map("requested_by_id")
  hostTherapistId String  @map("host_therapist_id")
  approvedById    String? @map("approved_by_id")
  groupCategoryId String? @map("group_category_id")

  scheduledAt     DateTime @map("scheduled_at")
  durationMinutes Int      @map("duration_minutes")
  maxMembers      Int      @map("max_members")

  priceMinor        BigInt  @map("price_minor")
  allowGuestJoin    Boolean @default(false) @map("allow_guest_join")
  requiresPayment   Boolean @default(false) @map("requires_payment")
  requiresAdminGate Boolean @default(false) @map("requires_admin_gate")

  jitsiRoomName   String? @map("jitsi_room_name")
  rejectionReason String? @map("rejection_reason")

  publishAt   DateTime? @map("publish_at")
  publishedAt DateTime? @map("published_at")
  approvedAt  DateTime? @map("approved_at")

  requestedBy   User?                    @relation("GroupTherapyRequestedBy", fields: [requestedById], references: [id])
  hostTherapist User?                    @relation("GroupTherapyHost", fields: [hostTherapistId], references: [id])
  approvedBy    User?                    @relation("GroupTherapyApprovedBy", fields: [approvedById], references: [id])
  groupCategory GroupCategory?           @relation(fields: [groupCategoryId], references: [id])
  invites       GroupTherapyInvite[]
  enrollments   GroupTherapyEnrollment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("group_therapy_sessions")
}

model GroupTherapyEnrollment {
  id String @id @default(cuid())

  sessionId  String              @map("session_id")
  session    GroupTherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String?             @map("user_id")
  guestEmail String?             @map("guest_email")
  guestName  String?             @map("guest_name")

  enrolledByAdminId   String?   @map("enrolled_by_admin_id")
  status              String
  amountMinor         BigInt?   @map("amount_minor")
  paymentId           String?   @map("payment_id")
  merchantTransaction String?   @map("merchant_transaction")
  paidAt              DateTime? @map("paid_at")
  joinedAt            DateTime? @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, userId, guestEmail])
  @@map("group_therapy_enrollments")
}

model GroupTherapyInvite {
  id              String              @id @default(cuid())
  sessionId       String              @map("session_id")
  patientUserId   String              @map("patient_user_id")
  invitedById     String              @map("invited_by_id")
  status          String
  amountMinor     BigInt              @map("amount_minor")
  message         String?
  paymentDeadline DateTime?           @map("payment_deadline")
  acceptedAt      DateTime?           @map("accepted_at")
  paidAt          DateTime?           @map("paid_at")
  joinedAt        DateTime?           @map("joined_at")
  paymentId       String?             @map("payment_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  session         GroupTherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  patient         User                @relation("GroupTherapyInvitePatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  invitedBy       User                @relation("GroupTherapyInviteBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([sessionId, patientUserId])
  @@index([patientUserId, status])
  @@index([sessionId, status])
  @@map("group_therapy_invites")
}

model ScreeningQuestion {
  id                                 String                    @id @default(uuid())
  templateId                         String
  prompt                             String
  sectionKey                         String                    @default("general")
  orderIndex                         Int
  isActive                           Boolean                   @default(true)
  createdAt                          DateTime                  @default(now())
  updatedAt                          DateTime                  @updatedAt
  providerExtraQuestionsFromTemplate ProviderExtraQuestion[]
  answers                            ScreeningAnswer[]
  options                            ScreeningQuestionOption[]
  template                           ScreeningTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, orderIndex])
  @@index([templateId, isActive])
  @@map("screening_questions")
}

model ScreeningQuestionOption {
