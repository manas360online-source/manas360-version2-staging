# ===============================
# MANAS360 Backend Environment
# Copy this file to .env and set real values
# ===============================

# Core
NODE_ENV=development
PORT=3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173
API_URL=http://localhost:3000
# Express trust proxy for AWS ALB / reverse proxies (1 is typical)
TRUST_PROXY=1

# Database & Cache
DATABASE_URL=postgresql://manas360:manas360@localhost:5432/manas360
REDIS_URL=redis://127.0.0.1:6379
DB_POOL_MAX=20

# JWT / Auth
JWT_ACCESS_SECRET=change-access-secret
JWT_REFRESH_SECRET=change-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=
COOKIE_SECURE=false
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
OTP_TTL_MINUTES=10
RESET_OTP_TTL_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=15
GOOGLE_CLIENT_ID=
MFA_ISSUER=manas360

# In multi-instance AWS deployments, disable background jobs on web replicas
# and run them on a single worker process/task.
ENABLE_BACKGROUND_JOBS=true

# Development-only shortcuts (keep false outside local dev)
# When true in NODE_ENV=development:
# - OTP verification checks can be bypassed for local signup/login testing
# - Razorpay signature check can be bypassed for local booking tests
DEV_VERIFICATION_BYPASS=true
DEV_PAYMENT_BYPASS=true

# Security
SESSION_NOTES_ENCRYPTION_KEY=change-session-notes-encryption-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# S3 / Storage
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PROFILE_PHOTO_SIGNED_URL_TTL_SECONDS=900
THERAPIST_DOCUMENT_SIGNED_URL_TTL_SECONDS=900
EXPORT_SIGNED_URL_TTL_SECONDS=3600

# PhonePe Platform Subscription Payments
# OAuth V2 (recommended):
# - Use SU... `PHONEPE_CLIENT_ID` + `PHONEPE_CLIENT_SECRET` for token API
# - Use M... `PHONEPE_MERCHANT_ID` for PG APIs
# - Payment APIs use `Authorization: O-Bearer <token>`
# - `PHONEPE_SALT_KEY` / `PHONEPE_SALT_INDEX` are optional (legacy checksum flow)
PHONEPE_ENV=preprod
PHONEPE_MODE=
PHONEPE_BASE_URL=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_OAUTH_URL=
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=
PHONEPE_WEBHOOK_SECRET=
# Comma-separated list of extra webhook source IPs to allow (beyond built-in PhonePe list)
PHONEPE_WEBHOOK_ALLOWED_IPS=
# Non-production only: bypass webhook source IP enforcement during staging validation
PHONEPE_WEBHOOK_IP_BYPASS=false
# Optional status endpoint override when merchant mapping differs.
# Supports {merchantId} and {transactionId} placeholders.
PHONEPE_STATUS_ENDPOINT_TEMPLATE=/pg/v1/status/{merchantId}/{transactionId}

PAYMENT_PROVIDER_SHARE_PERCENT=60
PAYMENT_PLATFORM_SHARE_PERCENT=40
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=3600
MIN_PAYOUT_MINOR=10000

# Jobs / Analytics
ANALYTICS_ROLLUP_INTERVAL_SECONDS=3600
ANALYTICS_ROLLUP_DEBOUNCE_SECONDS=60

# External integrations (Phase 2 / optional now)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku
CLAUDE_SONNET_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=512
CLAUDE_DAILY_TOKEN_BUDGET=100000
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_CDN_HOSTNAME=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRY=86400
AWS_SES_FROM=noreply@manas360.com
FREESOUND_API_KEY=

# Email delivery connector for platform notifications (optional)
# If set, backend posts outbound email payloads to this webhook.
EMAIL_PROVIDER=
EMAIL_WEBHOOK_URL=
EMAIL_FROM_NAME=MANAS360
EMAIL_FROM_ADDRESS=noreply@manas360.com
EMAIL_REPLY_TO=support@manas360.com

# Set EMAIL_PROVIDER=zoho to send platform admin invite emails through ZOHO_FLOW_WEBHOOK_URL.

# Platform admin invite email customization (optional)
ADMIN_INVITE_EMAIL_SUBJECT=Your MANAS360 admin invitation
ADMIN_INVITE_LOGIN_URL=

# Zoho Flow webhook (incoming) — set this to your Zoho Flow incoming webhook URL.
# Example (DO NOT COMMIT your real URL/key):
# ZOHO_FLOW_WEBHOOK_URL=https://flow.zoho.in/60067414515/flow/webhook/incoming?zapikey=YOUR_REAL_KEY&isdebug=false
# Optional shared secret for inbound verification from Zoho Flow (use for HMAC/header checks):
# ZOHO_FLOW_WEBHOOK_SECRET=change-to-a-random-secret
ZOHO_FLOW_WEBHOOK_URL=
ZOHO_FLOW_WEBHOOK_SECRET=

# Hosted admin bootstrap (optional)
# Enable only in controlled environments. Do not commit real passwords.
ADMIN_SEED_ENABLED=false
ADMIN_DEFAULT_PASSWORD=

ADMIN_SUPER_EMAIL=superadmin@manas360.com
ADMIN_SUPER_PASSWORD=
ADMIN_SUPER_FIRST_NAME=Super
ADMIN_SUPER_LAST_NAME=Admin

ADMIN_FINANCE_EMAIL=finance@manas360.com
ADMIN_FINANCE_PASSWORD=
ADMIN_FINANCE_FIRST_NAME=Finance
ADMIN_FINANCE_LAST_NAME=Manager

ADMIN_CLINICAL_EMAIL=clinical@manas360.com
ADMIN_CLINICAL_PASSWORD=
ADMIN_CLINICAL_FIRST_NAME=Clinical
ADMIN_CLINICAL_LAST_NAME=Director

ADMIN_COMPLIANCE_EMAIL=compliance@manas360.com
ADMIN_COMPLIANCE_PASSWORD=
ADMIN_COMPLIANCE_FIRST_NAME=Compliance
ADMIN_COMPLIANCE_LAST_NAME=Officer
