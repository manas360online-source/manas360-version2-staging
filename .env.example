# MANAS360 backend environment variables example

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/manas360?schema=public"
MDC_DATABASE_URL="postgresql://user:password@localhost:5432/manas360_mdc?schema=public"

# App
NODE_ENV=development
PORT=3000

# JWT secrets (required in staging/production)
JWT_ACCESS_SECRET=change-access-secret
JWT_REFRESH_SECRET=change-refresh-secret

# NMC verification
NMC_API_URL=https://www.nmc.org.in/MCIRest/open/getDataFromService?service=searchDoctor
# Optional API key if the external endpoint requires one
NMC_API_KEY=
VERIFICATION_TIMEOUT_MS=10000

# State Medical Council map (JSON or comma-separated KEY=URL pairs)
# Example JSON: {"MH":"https://smc-mh.example/api/search","DL":"https://smc-dl.example/api/search"}
SMC_API_MAP={}

# Zoho Flow webhook secret (used to validate incoming flow callbacks)
ZOHO_FLOW_WEBHOOK_SECRET=change_me

# Do not store production secrets in the repo.
